# Core
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
POSTGRES_USER=job_agent
POSTGRES_PASSWORD=job_agent
POSTGRES_DB=job_agent
DATABASE_URL=postgresql+psycopg://job_agent:job_agent@postgres:5432/job_agent

# Matching defaults
MIN_MATCH_SCORE=80
# Salary bracket is INR LPA. Auto-apply skips jobs with no salary unless disabled below.
PREFERRED_SALARY_MIN_LPA=
PREFERRED_SALARY_MAX_LPA=
SALARY_USD_TO_INR=83
AUTO_APPLY_REQUIRE_SALARY=true
AUTO_APPLY_MIN_MATCHED_SKILLS=3
BIG_COMPANY_NAMES=airbnb,stripe,databricks,mongodb,hashicorp,postman,vercel,netlify
SCHEDULER_TIMEZONE=Asia/Kolkata
DAILY_DISCOVERY_HOUR=8
DAILY_DISCOVERY_MINUTE=0
RUN_SCHEDULER=true
DAILY_AUTO_APPLY_ENABLED=true
DAILY_AUTO_APPLY_LIMIT=10
SAMPLE_JOBS_ENABLED=false
PUBLIC_JOB_APIS_ENABLED=true
BROWSER_JOB_BOARDS_ENABLED=false

# OpenAI
# GPT-5.4 mini is a strong cost/performance default for high-volume generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low

# Job discovery sources
GREENHOUSE_COMPANIES=
LEVER_COMPANIES=
COMPANY_CAREER_URLS=
PLAYWRIGHT_HEADLESS=true
LINKEDIN_SEARCH_URL=https://www.linkedin.com/jobs/search/?keywords={query}&location={location}
WELLFOUND_SEARCH_URL=https://wellfound.com/jobs
INSTAHYRE_SEARCH_URL=https://www.instahyre.com/search-jobs/
NAUKRI_SEARCH_URL=https://www.naukri.com/{query}-jobs-in-{location}
INDEED_SEARCH_URL=https://in.indeed.com/jobs?q={query}&l={location}

# Application safety
AUTO_APPLY_ENABLED=false
REQUIRE_APPLICATION_APPROVAL=true
APPLICATION_DRY_RUN=true

# Email / Gmail SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
OUTREACH_DRY_RUN=true

# Optional Google integrations
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_CALENDAR_ID=primary
